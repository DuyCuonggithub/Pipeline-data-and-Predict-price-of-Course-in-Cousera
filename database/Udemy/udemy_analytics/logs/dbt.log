  create  table "udemy_dw"."public_marts"."fct_course_snapshot__dbt_tmp"
  
  
    as
  
  (
    WITH source AS (
    SELECT * FROM "udemy_dw"."public_staging"."stg_courses"
),

ranked_source AS (
    SELECT *,
           -- Logic Snapshot: Lấy bản ghi mới nhất theo thời gian cào
           ROW_NUMBER() OVER (PARTITION BY course_id ORDER BY scraped_at DESC) as rn
    FROM source
),

latest_snapshot AS (
    SELECT 
        -- 1. Khóa liên kết
        course_id,

        -- 2. Các chỉ số metrics
        num_students,
        num_reviews,
        rating,

        -- 3. Chi tiết rating
        rating_1,
        rating_2,
        rating_3,
        rating_4,
        rating_5,

        -- 4. Metadata
        last_updated_date,
        scraped_at
        
    FROM ranked_source
    WHERE rn = 1
)

SELECT * FROM latest_snapshot
  );
  
