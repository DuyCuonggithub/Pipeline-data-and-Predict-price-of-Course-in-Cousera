  create  table "udemy_dw"."public_marts"."fct_price_history__dbt_tmp"
  
  
    as
  
  (
    WITH source AS (
    SELECT * FROM "udemy_dw"."public_staging"."stg_price_tracker"
)

SELECT
    -- [FIX] Dùng MD5 thay vì dbt_utils để không cần cài package
    MD5(CAST(course_id AS TEXT) || '-' || CAST(scraped_at AS TEXT)) AS history_id,
    
    course_id,
    list_price,
    sale_price,
    scraped_at AS recorded_at,
    
    CASE 
        WHEN list_price > 0 THEN ROUND((1 - (sale_price / list_price))::NUMERIC * 100, 0)
        ELSE 0 
    END AS discount_percentage,
    
    CASE 
        WHEN sale_price <= MIN(sale_price) OVER (PARTITION BY course_id) THEN TRUE 
        ELSE FALSE 
    END AS is_lowest_price_ever

FROM source
  );
  
