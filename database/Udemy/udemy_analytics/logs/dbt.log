  create  table "udemy_dw"."public_marts"."dim_date__dbt_tmp"
  
  
    as
  
  (
    

WITH date_boundaries AS (
    -- 1. Tìm ngày nhỏ nhất và lớn nhất trong toàn bộ dữ liệu
    SELECT
        -- Dùng LEAST/GREATEST để so sánh giữa các cột ngày trong cùng 1 dòng
        -- Sau đó dùng MIN/MAX để so sánh giữa các dòng
        MIN(LEAST(
            published_date, 
            last_updated_date, 
            scraped_at::DATE
        )) AS start_date,

        MAX(GREATEST(
            published_date, 
            last_updated_date, 
            scraped_at::DATE
        )) AS end_date
    FROM "udemy_dw"."public_staging"."stg_courses"
),

date_sequence AS (
    -- 2. Sinh ra chuỗi ngày liên tục từ Start -> End
    SELECT
        (generate_series(
            start_date::TIMESTAMP, 
            end_date::TIMESTAMP, 
            '1 day'::NTERVAL
        ))::DATE AS date_day
    FROM date_boundaries
)

-- 3. Tính toán các thuộc tính ngày tháng
SELECT
    date_day AS date_key,
    
    -- Các trường số (Dùng để sort hoặc tính toán)
    EXTRACT(YEAR FROM date_day) AS year,
    EXTRACT(MONTH FROM date_day) AS month,
    EXTRACT(DAY FROM date_day) AS day,
    EXTRACT(QUARTER FROM date_day) AS quarter,
    EXTRACT(ISODOW FROM date_day) AS day_of_week, -- 1=Monday, 7=Sunday
    
    -- Các trường tên (Dùng để hiển thị trên Dashboard)
    TO_CHAR(date_day, 'Month') AS month_name,      -- January, February...
    TO_CHAR(date_day, 'Day') AS day_name,          -- Monday, Tuesday...
    
    -- Cờ báo (Flags)
    CASE 
        WHEN EXTRACT(ISODOW FROM date_day) IN (6, 7) THEN true 
        ELSE false 
    END AS is_weekend,
    
    -- Định dạng hiển thị đẹp (Optional)
    TO_CHAR(date_day, 'YYYY-MM') AS year_month    -- 2024-12
    
FROM date_sequence
  );
  
