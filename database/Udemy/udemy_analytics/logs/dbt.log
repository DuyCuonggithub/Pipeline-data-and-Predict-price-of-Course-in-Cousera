[0m13:31:35.711087 [debug] [Thread-1 (]: On model.udemy_analytics.fct_price_history: /* {"app": "dbt", "dbt_version": "1.7.10", "profile_name": "udemy_analytics", "target_name": "dev", "node_id": "model.udemy_analytics.fct_price_history"} */

  
    

  create  table "udemy_dw"."public_marts"."fct_price_history__dbt_tmp"
  
  
    as
  
  (
    WITH price_data AS (
    SELECT * FROM "udemy_dw"."public_staging"."stg_price_tracker"
),

course_details AS (
    SELECT * FROM "udemy_dw"."public_marts"."dim_course"
),

-- [LOGIC MỚI] Gom nhóm giảng viên (Vì 1 khóa có nhiều GV)
-- Kết quả: "Nguyễn Văn A, Trần Thị B"
course_instructors AS (
    SELECT 
        b.course_id,
        -- Hàm STRING_AGG của Postgres giúp nối chuỗi
        STRING_AGG(i.instructor_name, ', ') AS instructor_names
    FROM "udemy_dw"."public_marts"."bridge_course_instructors" b
    JOIN "udemy_dw"."public_marts"."dim_instructor" i ON b.instructor_id = i.instructor_id
    GROUP BY b.course_id
),

-- Các bảng Lookup
categories AS (SELECT * FROM "udemy_dw"."public_marts"."dim_category"),
languages AS (SELECT * FROM "udemy_dw"."public_marts"."dim_language"),
levels AS (SELECT * FROM "udemy_dw"."public_marts"."dim_level")

SELECT
    -- 1. ID Khóa chính
    MD5(CAST(p.course_id AS TEXT) || '-' || CAST(p.scraped_at AS TEXT)) AS history_id,
    
    -- 2. Thông tin Giá (Biến động theo ngày)
    p.course_id,
    p.scraped_at AS recorded_at,
    p.list_price,
    p.sale_price,
    
    CASE 
        WHEN p.list_price > 0 THEN ROUND((1 - (p.sale_price / p.list_price))::NUMERIC * 100, 0)
        ELSE 0 
    END AS discount_percentage,
    
    CASE 
        WHEN p.sale_price <= MIN(p.sale_price) OVER (PARTITION BY p.course_id) THEN TRUE 
        ELSE FALSE 
    END AS is_lowest_price_ever,

    -- 3. Thông tin Khóa học (Tĩnh)
    COALESCE(c.title, p.title) AS title,
    c.headline,
    c.course_url,
    
    -- [MỚI] Các cột bạn yêu cầu
    c.last_updated_date,
    c.duration_hours,
    c.published_date,
    
    -- [MỚI] Tên giảng viên (đã nối chuỗi)
    COALESCE(ci.instructor_names, 'Unknown Instructor') AS instructor_names,
    
    -- 4. Thông tin Phân loại (Text)
    cat.category_name AS category,
    lang.language_name AS language,
    lvl.level_name AS level

FROM price_data p
-- Join để lấy chi tiết khóa học
LEFT JOIN course_details c ON p.course_id = c.course_id
-- Join để lấy tên giảng viên
LEFT JOIN course_instructors ci ON p.course_id = ci.course_id
-- Join để lấy tên phân loại
LEFT JOIN categories cat ON c.category_id = cat.category_id
LEFT JOIN languages lang ON c.language_id = lang.language_id
LEFT JOIN levels lvl ON c.level_id = lvl.level_id
  );
  
