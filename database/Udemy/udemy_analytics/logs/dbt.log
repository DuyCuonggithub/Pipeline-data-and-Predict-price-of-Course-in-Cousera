[0m09:24:45.907018 [debug] [Thread-1 (]: On model.udemy_analytics.stg_courses: /* {"app": "dbt", "dbt_version": "1.7.10", "profile_name": "udemy_analytics", "target_name": "dev", "node_id": "model.udemy_analytics.stg_courses"} */

  create view "udemy_dw"."public_staging"."stg_courses__dbt_tmp"
    
    
  as (
    WITH source AS (
    SELECT * FROM "udemy_dw"."raw"."courses"
),

cleaned AS (
    SELECT
        course_id,
        TRIM(title) AS title,
        TRIM(headline) AS headline,
        language,
        level,
        ROUND(course_duration_seconds / 3600.0, 1) AS duration_hours,
        publishes_date::DATE AS published_date,
        lasted_updated_date::DATE AS last_updated_date,
        COALESCE(original_price, 0) AS list_price,
        COALESCE(discount_price, original_price, 0) AS sale_price,
        num_students,
        num_reviews,
        ROUND(avg_rating_score, 1) AS rating,
        rating_distribution,
        _url AS course_url,
        _category AS category,
        _scraped_datetime AS scraped_at
    FROM source
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY course_id, _scraped_datetime 
        ORDER BY _scraped_datetime DESC
    ) = 1
),

ratings AS (
    SELECT
        c.*,
        -- [FIX] Cú pháp parse JSON chuẩn của PostgreSQL
        -- Giả sử rating_distribution là chuỗi JSON: [{"count": 10}, {"count": 20}...]
        CAST(c.rating_distribution::json->0->>'count' AS INT) AS rating_1,
        CAST(c.rating_distribution::json->1->>'count' AS INT) AS rating_2,
        CAST(c.rating_distribution::json->2->>'count' AS INT) AS rating_3,
        CAST(c.rating_distribution::json->3->>'count' AS INT) AS rating_4,
        CAST(c.rating_distribution::json->4->>'count' AS INT) AS rating_5
    FROM cleaned c
)

SELECT * FROM ratings
  );
