[0m09:43:55.025008 [debug] [Thread-3 (]: On model.udemy_analytics.dim_course: /* {"app": "dbt", "dbt_version": "1.7.10", "profile_name": "udemy_analytics", "target_name": "dev", "node_id": "model.udemy_analytics.dim_course"} */

  
    

  create  table "udemy_dw"."public_marts"."dim_course__dbt_tmp"
  
  
    as
  
  (
    WITH source_ranked AS (
    SELECT *,
           -- Đánh số thứ tự, dòng mới nhất là số 1
           ROW_NUMBER() OVER (PARTITION BY course_id ORDER BY scraped_at DESC) as rn
    FROM "udemy_dw"."public_staging"."stg_courses"
),

stg AS (
    -- Chỉ lấy dòng số 1 (mới nhất)
    SELECT * FROM source_ranked WHERE rn = 1
)

SELECT
    stg.course_id,
    stg.title,
    stg.headline,
    stg.course_url,
    stg.published_date, -- [FIX] Đã sửa từ 'publishes_date' thành 'published_date'
    stg.list_price,
    
    -- Lấy ID số từ các bảng Dim vệ tinh
    cat.category_id,
    lang.language_id,
    lvl.level_id

FROM stg
LEFT JOIN "udemy_dw"."public_marts"."dim_category" cat ON stg.category = cat.category_name
LEFT JOIN "udemy_dw"."public_marts"."dim_language" lang ON stg.language = lang.language_name
LEFT JOIN "udemy_dw"."public_marts"."dim_level" lvl ON stg.level = lvl.level_name
  );
  
